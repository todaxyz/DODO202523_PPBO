<?php

class DompetDigital {
    // 1. Encapsulation: Properti dibuat private
    private $pemilik;
    private $saldo;

    // 2. Complete the Constructor
    public function __construct($nama, $DepositoAwal) {
        $this->pemilik = $nama;
        
        // Add validation: initial balance cannot be negative
        if ($DepositoAwal < 0) {
            $this->saldo = 0;
            echo "Saldo awal tidak boleh kosong. Disetel ke 0.\n";
        } else {
            $this->saldo = $DepositoAwal;
        }
    }

    // 2. Method to view balance (Getter)
    public function getSaldo() {
        return "IDR " . number_format($this->saldo, 0, ',', '.');
    }

    // 3. Logic: Deposit
    public function deposit($amount) {
        if ($amount > 0) {
            $this->saldo += $amount;
            return true;
        }
        return false;
    }

    // 4. Logic: Withdraw
    public function ambil($amount) {
        if ($amount > 0 && $amount <= $this->saldo) {
            $this->saldo -= $amount;
            return true;
        }
        return false;
    }

    // 5. Live Coding Activity: Transfer feature
    public function transfer($amount, DompetDigital $targetWallet) {
        if ($this->ambil($amount)) {
            $targetWallet->deposit($amount);
            echo "Transfer berhasil\n";
            return true;
        }
        echo "Transfer gagal. Saldo tidak mencukupi.\n";
        return false;
    }
}

